#!/bin/bash
set -euo pipefail

echo "🧘‍♂️ Pre-commit pipeline..."

PYTHON_CMD="python"

git diff --cached --check

echo "🔎 Checking for merge conflict markers..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -v '^.githooks/pre-commit$' || true)

if [ -n "$STAGED_FILES" ]; then
  if echo "$STAGED_FILES" | xargs grep -nI "<<<<<<<\|=======\|>>>>>>>" 2>/dev/null; then
    echo "❌ Merge conflict markers found."
    exit 1
  fi
fi

echo "🔐 Checking for accidental secrets..."
if git diff --cached -- . ':(exclude).githooks/pre-commit' | grep -Ei "SUPABASE_SERVICE_ROLE_KEY|service_role|eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\." >/dev/null; then
  echo "❌ Possible secret detected."
  echo "   Check .env, service_role keys, or JWT-looking strings."
  exit 1
fi

echo "📄 Running scripts/generate_index.py..."
$PYTHON_CMD scripts/generate_index.py

git add FUNCTION_INDEX.md 2>/dev/null || true
git add docs/*.md 2>/dev/null || true
git add supabase/migrations/*.sql 2>/dev/null || true

echo "✅ Pre-commit complete."
exit 0
