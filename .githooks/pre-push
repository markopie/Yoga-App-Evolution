#!/bin/bash
set -euo pipefail

echo "Pre-push check..."

PYTHON_CMD="${PYTHON_CMD:-python}"
export PYTHONUTF8=1
export PYTHONIOENCODING=utf-8

if [ "${RUN_DB_BACKUP_ON_PUSH:-0}" = "1" ]; then
  echo "RUN_DB_BACKUP_ON_PUSH=1 detected. Running backup..."
  "$PYTHON_CMD" scripts/sync_and_backup.py
  echo "Backup complete."
  exit 0
fi

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || true)

if [ -n "$UPSTREAM" ]; then
  CHANGED_FILES=$(git diff --name-only "$UPSTREAM"..HEAD || true)
else
  CHANGED_FILES=$(git diff --name-only HEAD~1..HEAD || true)
fi

if echo "$CHANGED_FILES" | grep -q '^supabase/migrations/'; then
  echo "Migration changes detected. Running Supabase backup..."
  "$PYTHON_CMD" scripts/sync_and_backup.py
  echo "Backup complete."
else
  echo "No migration changes detected. Skipping backup."
fi

exit 0
