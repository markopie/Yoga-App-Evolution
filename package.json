{
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "npx http-server . -p 3000",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "npx eslint .",
    "test": "node --test",
    "audit": "python scripts/audit_timing_logic.py",
    "deploy": "bash deploy.sh",
    "index": "python scripts/generate_index.py",
    "backup": ".\\.venv\\Scripts\\python.exe scripts/sync_and_backup.py",
    "offline:size-report": "node scripts/offline-size-report.mjs",
    "db:refresh-analysis": ".\\.venv\\Scripts\\python.exe scripts/process_course_analysis_queue.py",
    "db:reset-local": "npx supabase db reset && npm run storage:sync-local",
    "storage:sync-local": "node scripts/local/sync-local-storage-assets.mjs --all",
    "verify:completion-metadata": "node scripts/active/verify_completion_duration_metadata.mjs",
    "seed:curriculum-testing-v2": "node scripts/active/seed_testing_curriculum_v2.mjs",
    "validate:curriculum-testing-v2": "node scripts/active/validate_testing_curriculum_v2.mjs",
    "seed:curriculum-combined-v1": "node scripts/active/seed_combined_school_year_curriculum_v1.mjs",
    "seed:curriculum-combined-v1:dry": "node scripts/active/seed_combined_school_year_curriculum_v1.mjs --dry-run",
    "validate:curriculum-combined-v1": "node scripts/active/validate_combined_school_year_curriculum_v1.mjs",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:ui": "playwright test --ui",
    "test:browser:report": "playwright show-report",
    "workflow": "node -e \"console.log(require('fs').readFileSync('docs/WORKFLOW.md','utf8'))\"",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:check": "git config --get core.hooksPath",
    "hooks:test": "node scripts/run_hook.cjs pre-commit",
    "hooks:test:pre-push": "node scripts/run_hook.cjs pre-push",
    "check": "npm run lint && npm test",
    "save": "git status --short && git add . && git commit -m",
    "push": "git push",
    "push:backup": "node -e \"const { spawnSync } = require('child_process'); const env = { ...process.env, RUN_DB_BACKUP_ON_PUSH: '1' }; const r = spawnSync('git', ['push'], { stdio: 'inherit', env }); process.exit(r.status ?? 1);\"",
    "legacy-build": "mkdir -p dist && cp index.html app.js dist/ && cp -r src styles fonts data dist/ && cp *.json dist/ 2>/dev/null || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@playwright/test": "^1.57.0",
    "@supabase/supabase-js": "^2.104.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint-plugin-check-file": "^3.3.1",
    "globals": "^17.4.0",
    "supabase": "^2.98.0",
    "vite": "^8.0.10"
  },
  "name": "yoga-app-evolution",
  "version": "1.0.0",
  "description": "A professional-grade yoga sequencing app built on a relational PostgreSQL database. Designed for high-performance practice, the UI prioritizes a low-cognitive-load \"Focus Mode,\" while the backend manages the complex relational mapping of the Iyengar yoga method.",
  "main": "app.js",
  "directories": {
    "doc": "docs"
  },
