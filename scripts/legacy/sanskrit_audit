def upload_to_supabase():
    # Load CSV - use 'str' to keep 001 from becoming 1
    df = pd.read_csv(CSV_PATH, encoding='utf-8-sig', dtype=str)
    
    print(f"🚀 Processing {len(df)} rows from CSV...")

    for i, row in df.iterrows():
        a_id = str(row['asana_id']).zfill(3) if not pd.isna(row['asana_id']) else None
        if not a_id: continue

        # A. Update 'asanas' table (Root Sanskrit and IAST)
        try:
            supabase.table("asanas").upsert({
                "id": a_id,
                "iast": row['asana_iast'],
                "devanagari": row['asana_devanagari']
            }).execute()
            # print(f"Row {i}: Root asana {a_id} synced.")
        except Exception as e:
            print(f"❌ Error in asanas table (Row {i}, ID {a_id}): {e}")

        # B. Update 'stages' table (Only if stage_id exists)
        s_id_raw = row['stage_id']
        if not pd.isna(s_id_raw) and str(s_id_raw).lower() != 'nan' and str(s_id_raw).strip() != '':
            try:
                # Convert stage_id to integer (bigint in Supabase)
                s_id = int(float(s_id_raw))
                
                supabase.table("stages").upsert({
                    "id": s_id,
                    "asana_id": a_id,
                    "stage_name": row['asana_iast'], # Mapping asana_iast to stage_name
                    "devanagari": row['asana_devanagari']
                }).execute()
                # print(f"Row {i}: Stage {s_id} synced.")
            except Exception as e:
                print(f"❌ Error in stages table (Row {i}, Stage {s_id_raw}): {e}")

    print("🏁 Sync Complete. Supabase is now updated with your clean data.")

if __name__ == "__main__":
    upload_to_supabase()