import os, json, time
from PIL import Image, ImageDraw, ImageFont
from workbench import supabase
import vertexai
from vertexai.preview.vision_models import ImageGenerationModel

# --- CONFIG ---
ASSET_DIR = r"C:\Projects\Yoga-App-Evolution\assets\yoga_cards"
FONT_DEV = r"C:\Projects\Yoga-App-Evolution\fonts\NotoSansDevanagari-Regular.ttf"
FONT_IAST = r"C:\Projects\Yoga-App-Evolution\fonts\NotoSerif-Regular.ttf"

vertexai.init(project="gen-lang-client-0495696648", location="us-central1")
model = ImageGenerationModel.from_pretrained("imagen-4.0-generate-001")

def run_single_card(stage_id):
    # Target only the new 'In a corner' record
    res = supabase.table("stages").select("*").eq("id", stage_id).execute()
    
    if not res.data:
        print(f"❌ Error: Stage ID {stage_id} not found.")
        return

    row = res.data[0]
    # Filename format: asanaID_stageID_name.png
    filename = f"{str(row['asana_id']).zfill(3)}_{str(row['id']).zfill(3)}_salamba_sirsasana_corner.png"
    
    # Using your successful "Bottom Third" prompt style
    prompt = f"""
    A compact architectural yoga sigil restricted to the BOTTOM THIRD of a plain light cream canvas.
    Design: {row['symbol_prompt']}. Essence: {row['oracle_lore']}.
    SPATIAL RULES: Top 65% must be EMPTY. Charcoal ink. No humans.
    """
    
    print(f"🚀 Generating single card for: {row['title']}...")
    
    try:
        images = model.generate_images(prompt=prompt, number_of_images=1, aspect_ratio="3:4")
        temp = f"temp_{filename}"
        images[0].save(location=temp)

        # Standard Text Overlay
        img = Image.open(temp)
        draw = ImageDraw.Draw(img)
        
        # --- DRAW TEXT (Simplified for this run) ---
        # Devanagari
        f_dev = ImageFont.truetype(FONT_DEV, 80)
        w_dev = draw.textbbox((0, 0), row['devanagari'], font=f_dev)[2]
        draw.text(((img.width - w_dev) / 2, img.height * 0.14), row['devanagari'], font=f_dev, fill="#333333")
        
        # IAST
        f_iast = ImageFont.truetype(FONT_IAST, 45)
        w_iast = draw.textbbox((0, 0), row['stage_name'], font=f_iast)[2]
        draw.text(((img.width - w_iast) / 2, img.height * 0.22), row['stage_name'], font=f_iast, fill="#333333")
        
        # Title/Variation
        f_title = ImageFont.truetype(FONT_IAST, 35)
        w_title = draw.textbbox((0, 0), row['title'], font=f_title)[2]
        draw.text(((img.width - w_title) / 2, img.height * 0.28), row['title'], font=f_title, fill="#666666")

        img.save(os.path.join(ASSET_DIR, filename))
        os.remove(temp)
        print(f"✅ Created: {filename}")

    except Exception as e:
        print(f"❌ Error: {e}")

if __name__ == "__main__":
    run_single_card(21)