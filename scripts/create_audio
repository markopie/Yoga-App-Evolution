import os
import re
import pandas as pd
from dotenv import load_dotenv
from workbench import supabase
from elevenlabs import VoiceSettings
from elevenlabs.client import ElevenLabs

# Assuming your environment already has 'supabase' defined from your workbench

# --- CONFIGURATION ---
load_dotenv()  # This looks for the .env file in your root
API_KEY = os.getenv("ELEVENLABS_API_KEY")
VOICE_ID = "ZUrEGyu8GFMwnHbvLhv2"
MODEL_ID = "eleven_multilingual_v2"
OUTPUT_FOLDER = "yoga_stage_audio"

client = ElevenLabs(api_key=API_KEY)

# The specific missing list provided
MISSING_ASANAS = [
    {"id": "217", "name": "Chandra Bhedana Pranayama"},
    {"id": "219", "name": "Jalandhara Bandha"},
    {"id": "220", "name": "Mula Bandha"},
    {"id": "229", "name": "Swastikasana"},
    {"id": "230", "name": "Ardha Padmasana"},
    {"id": "231", "name": "Sukhasana"},
    {"id": "232", "name": "Nasa Mudra"},
    {"id": "233", "name": "Paschima Namaskarasana"},
    {"id": "234", "name": "Ardha Halasana"},
    {"id": "235", "name": "Viparita Karani"}
]

if not os.path.exists(OUTPUT_FOLDER):
    os.makedirs(OUTPUT_FOLDER)

def generate_base_audio():
    print(f"🎙️ Generating audio for {len(MISSING_ASANAS)} base asanas...")

    for asana in MISSING_ASANAS:
        asana_id = asana["id"].zfill(3)
        name = asana["name"]
        
        # Safe Filename: 217_ChandraBhedanaPranayama.mp3
        safe_name = re.sub(r'[^a-zA-Z0-9]', '', name)
        filename = f"{asana_id}_{safe_name}.mp3"
        filepath = os.path.join(OUTPUT_FOLDER, filename)

        print(f"🔊 Speaking: {name}...")

        try:
            audio_generator = client.text_to_speech.convert(
                text=name, 
                voice_id=VOICE_ID,
                model_id=MODEL_ID,
                voice_settings=VoiceSettings(
                    stability=0.5, 
                    similarity_boost=0.75, 
                    style=0.0, 
                    use_speaker_boost=True, 
                    speed=0.80 # Slightly slower for Sanskrit clarity
                )
            )
            
            with open(filepath, "wb") as f:
                for chunk in audio_generator:
                    f.write(chunk)
            
        except Exception as e:
            print(f"❌ Error on {name}: {e}")

    print(f"\n✨ Done! Files in /{OUTPUT_FOLDER}")

if __name__ == "__main__":
    generate_base_audio()