import os
import google.auth
from google.cloud import service_usage_v1
from dotenv import load_dotenv

load_dotenv()

def audit_connection():
    creds_path = os.getenv("GOOGLE_APPLICATION_CREDENTIALS")
    if not creds_path or not os.path.exists(creds_path):
        print(f"❌ CREDENTIALS ERROR: Check your .env path for {creds_path}")
        return

    try:
        credentials, project_id = google.auth.default()
        client = service_usage_v1.ServiceUsageClient(credentials=credentials)
        
        # MODERN SYNTAX: Use a request dictionary instead of keyword arguments
        service_path = f"projects/{project_id}/services/aiplatform.googleapis.com"
        request = {"name": service_path}
        
        service = client.get_service(request=request)
        
        if service.state == service_usage_v1.types.State.ENABLED:
            print(f"✅ API STATUS: Vertex AI is ENABLED for {project_id}")
        else:
            print(f"⚠️  API STATUS: Vertex AI is DISABLED.")
            print(f"👉 Enable it here: https://console.cloud.google.com/apis/library/aiplatform.googleapis.com?project={project_id}")

    except Exception as e:
        print(f"❌ AUTH ERROR: {e}")

if __name__ == "__main__":
    audit_connection()