# Copy this file to .env.local for local development.
# Do not commit .env.local.
#
# After starting Supabase locally, run:
#   npx.cmd supabase status
# Then copy the API URL and publishable key into the values below.

VITE_SUPABASE_TARGET=local
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key

# Optional: keep a separate env file for the hosted project when needed.
# VITE_SUPABASE_TARGET=cloud
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-cloud-publishable-key
